# 黄氏家族寻根平台 - 环境变量配置示例
# 复制此文件为 .env 并填入实际值
# ⚠️ 不要提交 .env 到 Git！

# 服务器端口
PORT=3000

# 运行环境
NODE_ENV=production

# Redis 连接地址（可选，用于会话存储）
# 未配置时使用内存存储（降级方案）
REDIS_URL=redis://localhost:6379

# CORS 允许的域名（逗号分隔）
ALLOWED_ORIGINS=https://hxfund.cn,https://www.hxfund.cn

# SSL 证书配置（生产环境）
# SSL_CERT_PATH=/etc/nginx/ssl/hxfund.cn.crt
# SSL_KEY_PATH=/etc/nginx/ssl/hxfund.cn.key
