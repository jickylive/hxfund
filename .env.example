# 黄氏家族寻根平台 - 环境变量配置

# 通用配置
NODE_ENV=production
PORT=3000

# CORS 配置
ALLOWED_ORIGINS=https://hxfund.cn,https://www.hxfund.cn,https://api.hxfund.cn,https://qxu1606470020.my3w.com

# Redis 配置
REDIS_URL=redis://redis:6379

# API 速率限制配置
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30
RATE_LIMIT_MAX_CHAT_REQUESTS=10

# 日志级别
LOG_LEVEL=info

# 会话配置
SESSION_RETENTION_DAYS=30
SESSION_COMPRESS=true

# SSL 证书路径（容器内）
SSL_CERT_PATH=/etc/nginx/ssl/ssl_certificate.crt
SSL_KEY_PATH=/etc/nginx/ssl/ssl_private.key

# FTP 部署配置
FTP_HOST=your-ftp-server.com
FTP_USER=your-ftp-username
FTP_PASS=your-ftp-password
FTP_PORT=21
FTP_REMOTE=/

# 阿里云 FTP 虚拟主机配置（可选，如果与通用 FTP 配置不同）
ALIYUN_FTP_HOST=your-aliyun-ftp-host.com
ALIYUN_FTP_USER=your-aliyun-ftp-username
ALIYUN_FTP_PASS=your-aliyun-ftp-password
ALIYUN_FTP_PORT=21
ALIYUN_FTP_REMOTE_DIR=/htdocs
ALIYUN_FTP_SECURE=false  # 是否使用 FTPS (SSL)

# 阿里云部署配置
# =========================

# 阿里云 OSS 部署配置（传统方式）
ALIYUN_OSS_BUCKET_NAME=your-oss-bucket-name
ALIYUN_ACCESS_KEY_ID=your-access-key-id
ALIYUN_ACCESS_KEY_SECRET=your-access-key-secret
ALIYUN_OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com

# 阿里云 ECS 实例角色配置（STS 方式 - 更安全）
ECS_ROLE_NAME=your-ecs-role-name

# 阿里云 CDN 配置
ALIYUN_CDN_DOMAIN=www.hxfund.cn
ALIYUN_CDN_ORIGIN_TYPE=oss  # oss, ip, domain
ALIYUN_CDN_BACKUP_ORIGIN=your-backup-origin.com  # 备用源站

# 阿里云 RAM 配置
ALIYUN_RAM_ROLE_ARN=acs:ram::account-id:role/role-name
ALIYUN_STS_REGION=cn-hangzhou

# 阿里云其他服务配置
ALIYUN_REGION=cn-hangzhou
ALIYUN_ACCOUNT_ID=your-account-id

# 智能部署配置说明
# =========================
# 智能部署脚本 (deploy:aliyun:smart) 会自动检测运行环境：
# - 如果在配置了 RAM 角色的 ECS 实例上运行，则使用 STS 临时凭证
# - 如果在其他环境运行，则使用以下传统 AccessKey
# 
# 为使用智能部署，请确保设置以下变量：
# ALIYUN_OSS_BUCKET_NAME
# ALIYUN_ACCESS_KEY_ID
# ALIYUN_ACCESS_KEY_SECRET
# 
# 如果在 ECS 上运行，还需设置：
# ECS_ROLE_NAME

# FTP 部署配置说明
# =========================
# FTP 部署脚本 (deploy:aliyun:ftp) 使用以下变量：
# 
# 为使用 FTP 部署，请设置以下变量：
# ALIYUN_FTP_HOST (或 FTP_HOST)
# ALIYUN_FTP_USER (或 FTP_USER) 
# ALIYUN_FTP_PASS (或 FTP_PASS)
# 
# 可选变量：
# ALIYUN_FTP_PORT (或 FTP_PORT) - 默认 21
# ALIYUN_FTP_REMOTE_DIR (或 FTP_REMOTE) - 默认 /htdocs
# ALIYUN_FTP_SECURE (或 FTP_SECURE) - 是否使用 SSL，默认 false